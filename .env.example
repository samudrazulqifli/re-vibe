# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# GOOGLE_MAPS_API_KEY: Required for Google Maps JavaScript API + Places API.
GOOGLE_MAPS_API_KEY="MY_GOOGLE_MAPS_KEY"

# YOUTUBE_API_KEY: Required for YouTube Data API v3.
YOUTUBE_API_KEY="MY_YOUTUBE_KEY"

# GCS_BUCKET_NAME: Nama bucket Google Cloud Storage untuk simpan foto upload user.
GCS_BUCKET_NAME="re-vibe-uploads"

# GCS_PROJECT_ID: Google Cloud Project ID kamu (bukan nama project, tapi ID-nya).
GCS_PROJECT_ID="your-gcp-project-id"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
APP_URL="MY_APP_URL"
